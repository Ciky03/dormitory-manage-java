<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="cloud.ciky.system.mapper.SysMenuMapper">

    <!-- 通用查询映射结果 -->
    <resultMap id="BaseResultMap" type="cloud.ciky.system.model.entity.SysMenu">
        <id column="id" property="id" />
        <result column="parent_id" property="parentId" />
        <result column="tree_path" property="treePath" />
        <result column="name" property="name" />
        <result column="type" property="type" />
        <result column="route_name" property="routeName" />
        <result column="route_path" property="routePath" />
        <result column="component" property="component" />
        <result column="perm" property="perm" />
        <result column="keep_alive" property="keepAlive" />
        <result column="visible" property="visible" />
        <result column="sort" property="sort" />
        <result column="icon" property="icon" />
        <result column="pitch_icon" property="pitchIcon" />
        <result column="create_by" property="createBy" />
        <result column="create_time" property="createTime" />
        <result column="update_by" property="updateBy" />
        <result column="update_time" property="updateTime" />
        <result column="delflag" property="delflag" />
    </resultMap>

    <!-- 通用查询结果列 -->
    <sql id="Base_Column_List">
        id, parent_id, tree_path, name, type, route_name, route_path, component, perm, keep_alive, visible, sort, icon, pitch_icon, create_by, create_time, update_by, update_time, delflag
    </sql>

    <select id="listRoutes" resultType="cloud.ciky.system.model.vo.RouteVO">
        select
            m.id,
            m.parent_id,
            m.name,
            m.route_name,
            m.route_path,
            m.component,
            m.icon,
            m.pitch_icon,
            m.visible,
            m.keep_alive
        from sys_menu m
        inner join sys_role_menu rm on rm.menu_id = m.id and rm.delflag = 0
        inner join sys_role r on r.id = rm.role_id and r.delflag = 0 and r.status = 1
        where m.delflag = 0
        and m.type != '${@cloud.ciky.system.enums.MenuTypeEnum@BUTTON.getValue()}'
        <!-- ADMIN 可查看所有菜单  -->
        <if test="!roles.contains('ADMIN')">
            and r.code in
            <foreach collection="roles" item="role" open="(" close=")" separator=",">
                #{role}
            </foreach>
        </if>
    </select>

</mapper>
