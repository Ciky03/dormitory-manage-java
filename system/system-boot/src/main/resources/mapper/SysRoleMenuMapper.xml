<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="cloud.ciky.system.mapper.SysRoleMenuMapper">

    <!-- 通用查询映射结果 -->
    <resultMap id="BaseResultMap" type="cloud.ciky.system.model.entity.SysRoleMenu">
        <result column="role_id" property="roleId" />
        <result column="menu_id" property="menuId" />
        <result column="create_by" property="createBy" />
        <result column="create_time" property="createTime" />
        <result column="update_by" property="updateBy" />
        <result column="update_time" property="updateTime" />
        <result column="delflag" property="delflag" />
    </resultMap>

    <!-- 通用查询结果列 -->
    <sql id="Base_Column_List">
        role_id, menu_id, create_by, create_time, update_by, update_time, delflag
    </sql>
    <select id="selectMenuIdsByRoleId" resultType="java.lang.String">
        select rm.menu_id
        from sys_role_menu rm
                 inner join sys_menu m on rm.menu_id = m.id and m.delflag = 0
        where rm.role_id = #{roleId}
    </select>

</mapper>
