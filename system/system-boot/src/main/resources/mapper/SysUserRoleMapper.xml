<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="cloud.ciky.system.mapper.SysUserRoleMapper">

    <!-- 通用查询映射结果 -->
    <resultMap id="BaseResultMap" type="cloud.ciky.system.model.entity.SysUserRole">
        <id column="user_id" property="userId" />
        <id column="role_id" property="roleId" />
        <result column="create_by" property="createBy" />
        <result column="create_time" property="createTime" />
        <result column="update_by" property="updateBy" />
        <result column="update_time" property="updateTime" />
        <result column="delflag" property="delflag" />
    </resultMap>

    <!-- 通用查询结果列 -->
    <sql id="Base_Column_List">
        user_id, role_id, create_by, create_time, update_by, update_time, delflag
    </sql>

    <!--根据用户id获取角色编码-->
    <select id="findRoleCodesByUserId" resultType="java.lang.String">
        select r.code
        from sys_user_role ur
                 join sys_role r on ur.role_id = r.id
        where ur.user_id = #{userId}
    </select>

    <!-- 获取角色绑定的用户数 -->
    <select id="countUsersForRole" resultType="java.lang.Integer">
        select
            count(*)
        from
            sys_user_role ur
                inner join sys_role r on ur.role_id = r.id and r.delflag = 0
                inner join sys_user u on ur.user_id = u.id  and u.delflag = 0
        where
            ur.delflag = 0
            and ur.role_id = #{roleId}
    </select>

    <!-- 根据用户ID获取角色ID集合 -->
    <select id="selectRoleIdsByUserId" resultType="java.lang.String">
        select
            distinct r.id
        from
            sys_user_role ur
                inner join sys_role r on ur.role_id = r.id and r.delflag = 0 and r.status = 1
        where
            ur.user_id = #{userId}
    </select>

</mapper>
