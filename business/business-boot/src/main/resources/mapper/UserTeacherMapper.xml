<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="cloud.ciky.business.mapper.UserTeacherMapper">

    <!-- 通用查询映射结果 -->
    <resultMap id="BaseResultMap" type="cloud.ciky.business.model.entity.UserTeacher">
        <id column="id" property="id" />
        <result column="real_name" property="realName" />
        <result column="teacher_num" property="teacherNum" />
        <result column="entry_date" property="entryDate" />
        <result column="create_by" property="createBy" />
        <result column="create_time" property="createTime" />
        <result column="update_by" property="updateBy" />
        <result column="update_time" property="updateTime" />
        <result column="delflag" property="delflag" />
    </resultMap>

    <!-- 通用查询结果列 -->
    <sql id="Base_Column_List">
        id, real_name, teacher_num, entry_date, create_by, create_time, update_by, update_time, delflag
    </sql>

    <!-- 获取教师分页列表 -->
    <select id="selectTeacherPage" resultType="cloud.ciky.business.model.vo.TeacherPageVO">
        select
            t.id,
            t.real_name as realName,
            t.teacher_num as teacherNum,
            t.entry_date as entryDate
        from user_teacher t
        where t.delflag = 0
        <if test="@org.apache.commons.lang3.StringUtils@isNotBlank(query.keywords)">
            and (t.real_name like concat('%', #{query.keywords}, '%')
                or t.teacher_num like concat('%', #{query.keywords}, '%'))
        </if>
        order by t.create_time desc
    </select>

</mapper>
