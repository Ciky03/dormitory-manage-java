<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="cloud.ciky.business.mapper.UserStudentMapper">

    <!-- 通用查询映射结果 -->
    <resultMap id="BaseResultMap" type="cloud.ciky.business.model.entity.UserStudent">
        <id column="id" property="id" />
        <result column="real_name" property="realName" />
        <result column="student_num" property="studentNum" />
        <result column="admission_year" property="admissionYear" />
        <result column="graduation_year" property="graduationYear" />
        <result column="create_by" property="createBy" />
        <result column="create_time" property="createTime" />
        <result column="update_by" property="updateBy" />
        <result column="update_time" property="updateTime" />
        <result column="delflag" property="delflag" />
    </resultMap>

    <!-- 通用查询结果列 -->
    <sql id="Base_Column_List">
        id, real_name, student_num, admission_year, graduation_year, create_by, create_time, update_by, update_time, delflag
    </sql>

    <!-- 获取学生分页列表 -->
    <select id="selectStudentPage" resultType="cloud.ciky.business.model.vo.StudentPageVO">
        select
            s.id,
            s.real_name as realName,
            s.student_num as studentNum,
            null as className,
            s.admission_year as admissionYear,
            s.graduation_year as graduationYear
        from user_student s
        where s.delflag = 0
        <if test="@org.apache.commons.lang3.StringUtils@isNotBlank(query.keywords)">
            and (s.real_name like concat('%', #{query.keywords}, '%')
                or s.student_num like concat('%', #{query.keywords}, '%'))
        </if>
        order by s.create_time desc
    </select>

    <!--UserStudentForm参数映射-->
    <resultMap id="studentFormResultMap" type="cloud.ciky.business.model.form.UserStudentForm">
        <!--user_student表字段-->
        <id property="id" column="student_id"/>
        <result property="realName" column="student_real_name"/>
        <result property="studentNum" column="student_num"/>
        <result property="admissionYear" column="admission_year"/>
        <result property="graduationYear" column="graduation_year"/>
        <!--sys_user表字段-->
        <association property="userForm" javaType="cloud.ciky.system.model.form.UserForm">
            <id property="id" column="user_id"/>
            <result property="username" column="username"/>
            <result property="nickname" column="nickname"/>
            <result property="realName" column="user_real_name"/>
            <result property="userType" column="user_type"/>
            <result property="phone" column="phone"/>
            <result property="email" column="email"/>
        </association>
    </resultMap>
    
    <!-- 获取学生表单 -->
    <select id="selectStudentForm" resultMap="studentFormResultMap">
        select s.id        as student_id,
               s.real_name as student_real_name,
               s.student_num,
               s.admission_year,
               s.graduation_year,
               u.id        as user_id,
               u.username,
               u.nickname,
               u.real_name as user_real_name,
               u.user_type,
               u.phone,
               u.email
        from dm_business.user_student s
                 left join dm_system.sys_user u on u.business_user_id = s.id and u.delflag = 0
                    and u.user_type = ${@cloud.ciky.system.enums.UserTypeEnum@STUDENT.getValue()}
        where s.id = #{id}
            and s.delflag = 0
    </select>

</mapper>
