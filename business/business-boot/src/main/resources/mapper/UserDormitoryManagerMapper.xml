<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="cloud.ciky.business.mapper.UserDormitoryManagerMapper">

    <!-- 通用查询映射结果 -->
    <resultMap id="BaseResultMap" type="cloud.ciky.business.model.entity.UserDormitoryManager">
        <id column="id" property="id" />
        <result column="real_name" property="realName" />
        <result column="dm_num" property="dmNum" />
        <result column="entry_date" property="entryDate" />
        <result column="create_by" property="createBy" />
        <result column="create_time" property="createTime" />
        <result column="update_by" property="updateBy" />
        <result column="update_time" property="updateTime" />
        <result column="delflag" property="delflag" />
    </resultMap>

    <!-- 通用查询结果列 -->
    <sql id="Base_Column_List">
        id, real_name, dm_num, entry_date, create_by, create_time, update_by, update_time, delflag
    </sql>

    <!-- 获取宿管分页列表 -->
    <select id="selectDormitoryManagerPage" resultType="cloud.ciky.business.model.vo.DormitoryManagerPageVO">
        select
            dm.id,
            dm.real_name as realName,
            dm.dm_num as dmNum,
            dm.entry_date as entryDate
        from user_dormitory_manager dm
        where dm.delflag = 0
        <if test="@org.apache.commons.lang3.StringUtils@isNotBlank(query.keywords)">
            and (dm.real_name like concat('%', #{query.keywords}, '%')
                or dm.dm_num like concat('%', #{query.keywords}, '%'))
        </if>
        order by dm.create_time desc
    </select>

</mapper>
